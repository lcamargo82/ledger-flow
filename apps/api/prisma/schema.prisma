generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantKind {
  PLATFORM
  CUSTOMER
}

enum TenantInvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum PermissionScope {
  TENANT
  PLATFORM
}

model Tenant {
  id        String     @id @default(uuid())
  name      String
  slug      String     @unique
  kind      TenantKind @default(CUSTOMER)
  timezone  String     @default("America/Sao_Paulo")
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  users                 User[]
  roles                 Role[]
  subscription          TenantSubscription?
  authAttempts          AuthAttempt[]
  customers             Customer[]
  payments              Payment[]
  paymentEvents         PaymentEvent[]
  gatewayConfigurations GatewayConfiguration[]
  gatewayReferences     GatewayCustomerReference[]
  webhookInboxEvents    WebhookInboxEvent[]
  adminInvitations      TenantAdminInvitation[]
  outboxEvents          OutboxEvent[]
  asyncJobExecutions    AsyncJobExecution[]

  @@map("tenants")
}

model User {
  id                  String    @id @default(uuid())
  tenantId            String
  name                String
  email               String
  passwordHash        String
  isPlatformAdmin     Boolean   @default(false)
  active              Boolean   @default(true)
  lastLoginAt         DateTime?
  lastLoginIp         String?
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tenant                 Tenant                  @relation(fields: [tenantId], references: [id])
  roles                  UserRole[]
  refreshTokens          RefreshToken[]
  sessions               UserSession[]
  passwordResetTokens    PasswordResetToken[]
  tenantAdminInvitations TenantAdminInvitation[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  key         String
  description String?
  system      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  users       UserRole[]
  permissions RolePermission[]

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("roles")
}

model Permission {
  id          String          @id @default(uuid())
  key         String          @unique
  description String?
  scope       PermissionScope @default(TENANT)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  roles RolePermission[]

  @@map("permissions")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  revokedAt DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  session UserSession?

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model UserSession {
  id              String    @id @default(uuid())
  userId          String
  refreshTokenId  String?   @unique
  ipAddress       String?
  userAgent       String?
  deviceName      String?
  deviceType      String?
  browser         String?
  operatingSystem String?
  active          Boolean   @default(true)
  revokedAt       DateTime?
  expiresAt       DateTime
  lastSeenAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken RefreshToken? @relation(fields: [refreshTokenId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([refreshTokenId])
  @@index([active])
  @@index([ipAddress])
  @@index([createdAt])
  @@index([expiresAt])
  @@map("user_sessions")
}

model AuthAttempt {
  id            String   @id @default(uuid())
  tenantId      String?
  email         String
  ipAddress     String?
  userAgent     String?
  success       Boolean
  failureReason String?
  createdAt     DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([email])
  @@index([ipAddress])
  @@index([success])
  @@index([createdAt])
  @@map("auth_attempts")
}

enum CustomerType {
  INDIVIDUAL
  COMPANY
}

model Customer {
  id        String       @id @default(uuid())
  tenantId  String
  name      String
  email     String?
  document  String?
  phone     String?
  type      CustomerType @default(INDIVIDUAL)
  active    Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  tenant            Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payments          Payment[]
  gatewayReferences GatewayCustomerReference[]

  @@unique([tenantId, email])
  @@unique([tenantId, document])
  @@index([tenantId])
  @@index([tenantId, active])
  @@index([tenantId, type])
  @@index([tenantId, createdAt])
  @@index([tenantId, name])
  @@index([tenantId, email])
  @@index([tenantId, document])
  @@map("customers")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@index([usedAt])
  @@index([createdAt])
  @@map("password_reset_tokens")
}

model TenantAdminInvitation {
  id              String                 @id @default(uuid())
  tenantId        String
  userId          String
  email           String
  tokenHash       String                 @unique
  status          TenantInvitationStatus @default(PENDING)
  expiresAt       DateTime
  acceptedAt      DateTime?
  revokedAt       DateTime?
  createdByUserId String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([email])
  @@index([status])
  @@index([expiresAt])
  @@index([createdAt])
  @@map("tenant_admin_invitations")
}

model AuditLog {
  id          String           @id @default(uuid())
  scope       PermissionScope?
  severity    AuditSeverity?
  tenantId    String?
  actorUserId String?
  actorType   AuditActorType?
  source      String?
  entityType  String?
  entityId    String?
  action      String
  summary     String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  traceId     String?
  createdAt   DateTime         @default(now())

  @@index([tenantId])
  @@index([action])
  @@index([severity])
  @@index([actorType])
  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([tenantId, createdAt])
  @@map("audit_logs")
}

enum AuditSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AuditActorType {
  USER
  PLATFORM_ADMIN
  SYSTEM
  WEBHOOK
  WORKER
}

enum PaymentProvider {
  STRIPE
  ASAAS
  MERCADO_PAGO
  PAGBANK
  PAGARME
}

enum GatewayEnvironment {
  SANDBOX
  TEST
  LIVE
}

enum GatewayConfigurationStatus {
  ACTIVE
  INACTIVE
  DISABLED
}

enum GatewayHealthStatus {
  UNKNOWN
  HEALTHY
  DEGRADED
  UNHEALTHY
}

model GatewayConfiguration {
  id                     String                     @id @default(uuid())
  tenantId               String
  provider               PaymentProvider
  environment            GatewayEnvironment
  status                 GatewayConfigurationStatus @default(INACTIVE)
  priority               Int                        @default(100)
  displayName            String?
  supportedMethods       Json?
  encryptedCredentials   String?
  credentialsFingerprint String?
  healthStatus           GatewayHealthStatus        @default(UNKNOWN)
  lastHealthCheckAt      DateTime?
  lastHealthCheckMessage String?
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt

  tenant             Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payments           Payment[]
  gatewayReferences  GatewayCustomerReference[]
  webhookInboxEvents WebhookInboxEvent[]

  @@unique([tenantId, provider, environment])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, provider])
  @@index([tenantId, priority])
  @@index([provider, environment])
  @@map("gateway_configurations")
}

enum PaymentStatus {
  PENDING
  PROCESSING
  APPROVED
  FAILED
  CANCELED
  REFUNDED
}

enum PaymentMethod {
  PIX
  BOLETO
  CARD
  BANK_TRANSFER
  OTHER
}

enum PaymentExecutionMode {
  EXTERNAL_GATEWAY
  MANUAL
  INTERNAL
}

model Payment {
  id                     String               @id @default(uuid())
  tenantId               String
  customerId             String
  reference              String
  externalReference      String?
  amount                 Int
  currency               String               @default("BRL")
  method                 PaymentMethod
  status                 PaymentStatus        @default(PENDING)
  executionMode          PaymentExecutionMode @default(EXTERNAL_GATEWAY)
  description            String?
  dueDate                DateTime?
  metadata               Json?
  idempotencyKeyHash     String
  idempotencyRequestHash String
  provider               PaymentProvider?
  providerPaymentId      String?
  providerStatus         String?
  providerUpdatedAt      DateTime?
  providerInvoiceUrl     String?
  providerBankSlipUrl    String?
  providerPixCopyPaste   String?
  providerPixExpiresAt   DateTime?
  providerPaymentUrl     String?
  gatewayConfigurationId String?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  canceledAt             DateTime?
  refundedAt             DateTime?

  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer             Customer              @relation(fields: [customerId], references: [id], onDelete: Restrict)
  gatewayConfiguration GatewayConfiguration? @relation(fields: [gatewayConfigurationId], references: [id], onDelete: SetNull)
  events               PaymentEvent[]
  webhookInboxEvents   WebhookInboxEvent[]

  @@unique([tenantId, reference])
  @@unique([tenantId, idempotencyKeyHash])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, customerId])
  @@index([tenantId, createdAt])
  @@index([tenantId, reference])
  @@index([customerId])
  @@index([provider, providerPaymentId])
  @@index([gatewayConfigurationId])
  @@map("payments")
}

model PaymentEvent {
  id             String         @id @default(uuid())
  tenantId       String
  paymentId      String
  type           String
  previousStatus PaymentStatus?
  currentStatus  PaymentStatus?
  message        String?
  metadata       Json?
  createdAt      DateTime       @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([paymentId])
  @@index([type])
  @@index([createdAt])
  @@map("payment_events")
}

model GatewayCustomerReference {
  id                     String          @id @default(uuid())
  tenantId               String
  customerId             String
  gatewayConfigurationId String
  provider               PaymentProvider
  providerCustomerId     String
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  tenant               Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer             Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  gatewayConfiguration GatewayConfiguration @relation(fields: [gatewayConfigurationId], references: [id], onDelete: Cascade)

  @@unique([gatewayConfigurationId, customerId])
  @@unique([gatewayConfigurationId, providerCustomerId])
  @@index([tenantId])
  @@index([customerId])
  @@index([gatewayConfigurationId])
  @@index([provider, providerCustomerId])
  @@map("gateway_customer_references")
}

enum WebhookProvider {
  ASAAS
  STRIPE
  MERCADO_PAGO
  PAGBANK
  PAGARME
}

enum WebhookProcessingStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  IGNORED
  FAILED
  UNMATCHED
  INVALID
}

model WebhookInboxEvent {
  id                     String                  @id @default(uuid())
  provider               WebhookProvider
  providerEventId        String
  eventType              String
  providerPaymentId      String?
  externalReference      String?
  providerPaymentStatus  String?
  tenantId               String?
  paymentId              String?
  gatewayConfigurationId String?
  status                 WebhookProcessingStatus @default(RECEIVED)
  payloadHash            String
  payloadSummary         Json?
  receivedAt             DateTime                @default(now())
  processedAt            DateTime?
  failedAt               DateTime?
  failureReason          String?
  attemptCount           Int                     @default(0)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  tenant               Tenant?               @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  payment              Payment?              @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  gatewayConfiguration GatewayConfiguration? @relation(fields: [gatewayConfigurationId], references: [id], onDelete: SetNull)

  @@unique([provider, providerEventId])
  @@index([provider])
  @@index([eventType])
  @@index([status])
  @@index([tenantId])
  @@index([paymentId])
  @@index([gatewayConfigurationId])
  @@index([receivedAt])
  @@index([providerPaymentId])
  @@index([externalReference])
  @@map("webhook_inbox_events")
}

enum SubscriptionPlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
  CUSTOM
}

enum TenantSubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELED
}

model TenantSubscription {
  id                            String                   @id @default(uuid())
  tenantId                      String                   @unique
  plan                          SubscriptionPlan         @default(FREE)
  status                        TenantSubscriptionStatus @default(TRIAL)
  trialEndsAt                   DateTime?
  currentPeriodStart            DateTime?
  currentPeriodEnd              DateTime?
  externalSubscriptionReference String?
  notes                         String?
  createdAt                     DateTime                 @default(now())
  updatedAt                     DateTime                 @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([plan])
  @@index([status])
  @@index([currentPeriodEnd])
  @@map("tenant_subscriptions")
}

enum OutboxEventStatus {
  PENDING
  PUBLISHING
  PUBLISHED
  FAILED
  CANCELED
}

enum AsyncJobStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  RETRY_SCHEDULED
  DEAD_LETTERED
  FAILED
}

model OutboxEvent {
  id            String  @id @default(uuid())
  tenantId      String?
  aggregateType String
  aggregateId   String
  eventType     String
  eventVersion  Int     @default(1)

  payload     Json
  payloadHash String

  status          OutboxEventStatus @default(PENDING)
  publishAttempts Int               @default(0)
  availableAt     DateTime          @default(now())
  publishedAt     DateTime?
  lockedAt        DateTime?
  lockOwner       String?
  leaseExpiresAt  DateTime?

  lastErrorCode    String?
  lastErrorSummary String?

  traceId         String?
  replayOfEventId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([status, availableAt])
  @@index([tenantId, createdAt])
  @@index([eventType, status])
  @@index([aggregateType, aggregateId])
  @@index([traceId])
  @@index([replayOfEventId])
  @@map("outbox_events")
}

model AsyncJobExecution {
  id            String  @id @default(uuid())
  outboxEventId String
  consumerName  String
  tenantId      String?

  status       AsyncJobStatus @default(PENDING)
  attemptCount Int            @default(0)

  startedAt   DateTime?
  completedAt DateTime?
  nextRetryAt DateTime?

  lastErrorCode    String?
  lastErrorSummary String?

  traceId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@unique([outboxEventId, consumerName])
  @@index([status, nextRetryAt])
  @@index([tenantId, status])
  @@index([traceId])
  @@map("async_job_executions")
}
