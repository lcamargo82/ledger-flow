# .env.example

# ============================================================
# LedgerFlow — Environment Variables Example
# ============================================================
# Copy this file to .env before running the project locally:
#
# cp .env.example .env
#
# Windows PowerShell:
# Copy-Item .env.example .env
#
# Never commit your real .env file.
# Do not use production secrets in local development.
# ============================================================


# ============================================================
# Application
# ============================================================

NODE_ENV=development
TZ=UTC

APP_NAME=LedgerFlow

# Public URLs accessed from your browser/host machine.
APP_URL=http://localhost:5180
API_URL=http://localhost:3010
WEB_URL=http://localhost:5180


# ============================================================
# Docker Port Mapping
# ============================================================
# INTERNAL ports are used inside Docker containers.
# HOST ports are exposed on your computer.
#
# Example:
# HOST_API_PORT=3010
# API_PORT=3000
#
# Means:
# http://localhost:3010 -> container api:3000
# ============================================================

API_HOST=0.0.0.0
API_PORT=3000
HOST_API_PORT=3010

WEB_HOST=0.0.0.0
WEB_PORT=5173
HOST_WEB_PORT=5180


# ============================================================
# Frontend — Vite
# ============================================================
# These variables are used by the browser.
# Therefore, they must point to localhost HOST ports.
# ============================================================

VITE_APP_NAME=LedgerFlow
VITE_APP_ENV=development

VITE_API_BASE_URL=http://localhost:3010
VITE_WS_BASE_URL=ws://localhost:3010

VITE_DEFAULT_LOCALE=pt-BR
VITE_DEFAULT_TIMEZONE=America/Sao_Paulo


# ============================================================
# PostgreSQL
# ============================================================
# POSTGRES_PORT is the internal container port.
# POSTGRES_PUBLIC_PORT is the port exposed on your computer.
#
# API inside Docker uses:
# postgres:5432
#
# Your host machine uses:
# localhost:55432
# ============================================================

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_PUBLIC_PORT=55432

POSTGRES_DB=ledgerflow
POSTGRES_USER=ledgerflow
POSTGRES_PASSWORD=ledgerflow
PORT=3333
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ledgerflow?schema=public"

GATEWAY_CREDENTIALS_ENCRYPTION_KEY=


# ============================================================
# MongoDB
# ============================================================
# API inside Docker uses:
# mongodb:27017
#
# Your host machine uses:
# localhost:27018
# ============================================================

MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_PUBLIC_PORT=27018

MONGODB_DATABASE=ledgerflow
MONGODB_USERNAME=ledgerflow
MONGODB_PASSWORD=ledgerflow

MONGODB_URL=mongodb://ledgerflow:ledgerflow@mongodb:27017/ledgerflow?authSource=admin


# ============================================================
# Redis
# ============================================================
# API inside Docker uses:
# redis:6379
#
# Your host machine uses:
# localhost:6380
# ============================================================

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PUBLIC_PORT=6380

REDIS_PASSWORD=
REDIS_DB=0

REDIS_URL=redis://redis:6379


# ============================================================
# RabbitMQ
# ============================================================
# API inside Docker uses:
# rabbitmq:5672
#
# Your host machine uses:
# AMQP: localhost:5682
# UI:   http://localhost:15682
# ============================================================

RABBITMQ_HOST=rabbitmq

RABBITMQ_AMQP_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

RABBITMQ_PUBLIC_AMQP_PORT=5682
RABBITMQ_PUBLIC_MANAGEMENT_PORT=15682

RABBITMQ_DEFAULT_USER=ledgerflow
RABBITMQ_DEFAULT_PASS=ledgerflow

RABBITMQ_URL=amqp://ledgerflow:ledgerflow@rabbitmq:5672


# ============================================================
# Mailpit
# ============================================================
# API inside Docker sends email to:
# mailpit:1025
#
# Your host machine opens UI at:
# http://localhost:8026
# ============================================================

MAILPIT_SMTP_PORT=1026
MAILPIT_UI_PORT=8026


# ============================================================
# Mail / SMTP
# ============================================================

SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

SMTP_FROM_NAME=LedgerFlow
SMTP_FROM_EMAIL=no-reply@ledgerflow.local


# ============================================================
# JWT / Auth
# ============================================================

JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCK_MINUTES=15

PASSWORD_RESET_TOKEN_EXPIRES_IN=30m
EMAIL_VERIFICATION_TOKEN_EXPIRES_IN=24h


# ============================================================
# Encryption
# ============================================================
# ENCRYPTION_KEY and GATEWAY_CREDENTIALS_ENCRYPTION_KEY should be
# strong 32-byte keys in real environments.
# To generate a new 32-byte key in base64, run this command in your terminal:
# openssl rand -base64 32
#
# Never use these values in production.
# Never commit real encryption keys.
# ============================================================

ENCRYPTION_KEY=change-me-32-bytes-local-key-000
GATEWAY_CREDENTIALS_ENCRYPTION_KEY=vKx+V/R2rB5Lh7JkR9vPqWtZ4oX9T/l8wGqNfM5cHgE=


# ============================================================
# Stripe
# ============================================================
# Use Stripe test keys only in local development.
# ============================================================

STRIPE_SECRET_KEY=sk_test_change_me
STRIPE_WEBHOOK_SECRET=whsec_change_me
STRIPE_API_VERSION=2024-06-20


# ============================================================
# Payment Providers — Asaas Sandbox
# ============================================================
# IMPORTANT: Asaas API keys always start with "$aact_...".
# When using Docker Compose, the "$" character must be escaped using "&&" or "$$"
# inside the .env file.
# 
# Example: If your key is $aact_12345, you must write $$aact_12345
# ============================================================

ASAAS_SANDBOX_API_KEY=$$aact_coloque_sua_chave_aqui_para_docker
ASAAS_WEBHOOK_AUTH_TOKEN=seu_token_secreto_de_webhook
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
LEDGERFLOW_DEMO_TENANT_SLUG=ledgerflow-demo

MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_BASE_URL=https://api.mercadopago.com


# ============================================================
# CORS
# ============================================================
# CORS_ORIGIN should point to the frontend HOST URL.
# ============================================================

CORS_ORIGIN=http://localhost:5180
CORS_CREDENTIALS=true


# ============================================================
# Rate Limiting
# ============================================================

RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

AUTH_RATE_LIMIT_TTL=60
AUTH_RATE_LIMIT_MAX=10


# ============================================================
# API Documentation
# ============================================================

SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs

REDOC_ENABLED=true
REDOC_PATH=api/reference


# ============================================================
# Observability
# ============================================================

LOG_LEVEL=debug
LOG_PRETTY=true

OTEL_ENABLED=false
OTEL_SERVICE_NAME=ledgerflow-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9464

PROMETHEUS_PORT_PUBLIC=9091
GRAFANA_PORT=3002

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin


# ============================================================
# Datadog — Optional
# ============================================================

DATADOG_ENABLED=false

DD_SERVICE=ledgerflow-api
DD_ENV=development
DD_VERSION=1.0.0
DD_API_KEY=
DD_SITE=datadoghq.com


# ============================================================
# Reports / Exports
# ============================================================

REPORTS_TEMP_DIR=/tmp/ledgerflow/reports
REPORTS_MAX_SYNC_ROWS=10000
REPORTS_FILE_EXPIRATION_DAYS=7


# ============================================================
# Webhooks
# ============================================================

WEBHOOK_OUTBOUND_MAX_ATTEMPTS=5
WEBHOOK_OUTBOUND_TIMEOUT_MS=10000
WEBHOOK_SIGNATURE_TOLERANCE_SECONDS=300


# ============================================================
# Workers
# ============================================================

WORKERS_ENABLED=true

OUTBOX_WORKER_ENABLED=true
EMAIL_WORKER_ENABLED=true
WEBHOOK_WORKER_ENABLED=true
REPORT_WORKER_ENABLED=true
NOTIFICATION_WORKER_ENABLED=true

WORKER_CONCURRENCY=5

# ============================================================
# Prisma Studio
# ============================================================

HOST_PRISMA_STUDIO_PORT=5555
PRISMA_STUDIO_PORT=5555

# ============================================================
# Async Reliability (Outbox / Worker / Limits)
# ============================================================
OUTBOX_DISPATCH_BATCH_SIZE=50
OUTBOX_DISPATCH_INTERVAL_MS=2000
OUTBOX_LEASE_DURATION_SECONDS=60
EXTERNAL_PROVIDER_DEFAULT_CONCURRENCY=3
EXTERNAL_PROVIDER_DEFAULT_MIN_INTERVAL_MS=500
RABBITMQ_PREFETCH=10
